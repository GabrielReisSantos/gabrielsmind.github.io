---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const pageTitle = project.data.title ?? "Project";
const pageDescription = project.data.description ?? "Project document";
---

<BaseLayout title={`${pageTitle} | GabrielsMind`} description={pageDescription}>
  <section class="project-doc section">
    <article class="doc-shell">
      <Content />
    </article>
  </section>

  <style>
    .project-doc {
      padding-top: 8rem;
    }

    .doc-shell {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem;
      border-radius: 24px;
      background: rgba(8, 14, 28, 0.42);
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 18px 48px rgba(0, 0, 0, 0.24);
    }

    .doc-shell :global(h1) {
      font-size: clamp(2.3rem, 5vw, 4rem);
      line-height: 1.02;
      margin-top: 0;
      margin-bottom: 1.25rem;
      letter-spacing: -0.03em;
    }

    .doc-shell :global(h2) {
      margin-top: 2.25rem;
      margin-bottom: 0.8rem;
      font-size: 1.7rem;
      line-height: 1.1;
    }

    .doc-shell :global(h3) {
      margin-top: 1.75rem;
      margin-bottom: 0.7rem;
      font-size: 1.25rem;
    }

    .doc-shell :global(p),
    .doc-shell :global(li) {
      color: var(--muted);
    }

    .doc-shell :global(ul),
    .doc-shell :global(ol) {
      padding-left: 1.3rem;
    }

    .doc-shell :global(code) {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      font-size: 0.92em;
    }

    .doc-shell :global(pre) {
      overflow-x: auto;
      padding: 1rem;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .doc-shell :global(blockquote) {
      margin: 1.5rem 0;
      padding: 0.75rem 1rem;
      border-left: 4px solid var(--accent);
      background: rgba(255, 255, 255, 0.03);
      color: var(--muted);
    }
  </style>
</BaseLayout>
