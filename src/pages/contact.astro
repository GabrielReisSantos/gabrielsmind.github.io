---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact | GabrielsMind" description="Contact Gabriel.">
  <section class="section">
    <p class="eyebrow">Contact</p>
    <h1>Get in touch</h1>
    <p class="lead">
      The cleanest way to reach me is by email.
    </p>

    <div class="card">
      <p><strong>Email:</strong> <a href="mailto:gabriel@gabrielsmind.io">gabriel@gabrielsmind.io</a></p>
      <p><strong>Portfolio domain:</strong> <a href="https://gabrielsmind.io">gabrielsmind.io</a></p>
      <p><strong>LinkedIn:</strong> Add your profile link here.</p>
      <p class="muted">Later, if you want, we can add a proper form service instead of exposing only email.</p>
    </div>
  </section>
</BaseLayout>
