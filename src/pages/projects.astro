---
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = [
  {
    title: "SOC Lab Automation",
    description: "Detection, triage, enrichment, and response workflows using tools like Wazuh, TheHive, and Shuffle."
  },
  {
    title: "Phishing Triage Platform",
    description: "A project to analyze suspicious emails, domains, and IPs with automated enrichment and scoring."
  },
  {
    title: "GabrielsMind Study Tools",
    description: "AI-powered learning tools for cybersecurity study, flashcards, document Q&A, and multilingual support."
  }
];
---

<BaseLayout title="Projects | GabrielsMind" description="Selected cybersecurity projects and labs by Gabriel.">
  <section class="section">
    <p class="eyebrow">Projects</p>
    <h1>Selected Projects</h1>
    <div class="grid">
      {projects.map((project) => (
        <article class="card">
          <h2>{project.title}</h2>
          <p class="muted">{project.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
