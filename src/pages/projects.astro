---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SectionIntro from "../components/SectionIntro.astro";
import ProjectCard from "../components/ProjectCard.astro";

const flagshipProjects = [
  {
    title: "Proxmox Cluster Security Lab",
    text: "A segmented multi-node security lab built to support SOC workflows, hostile-zone testing, malware research isolation, and controlled adversary simulation.",
    tags: ["Proxmox", "OPNsense", "Segmentation", "Infrastructure"],
    href: "/projects/proxmox-cluster-security-lab/",
    linkLabel: "Read project →",
  },
  {
    title: "GabrielsMind Enterprise Defense",
    text: "A public project focused on practical enterprise defense thinking, security architecture, and hands-on defensive workflows built to connect technical controls with real operational use.",
    tags: ["Enterprise Defense", "Security Architecture", "Blue Team"],
    href: "https://github.com/GabrielReisSantos/gabrielsmind_enterprise_defense",
    linkLabel: "View repository →",
  },
  {
    title: "My Home SOC Lab",
    text: "A home SOC lab project built to explore monitoring, detection, logging, and investigation workflows in a practical environment designed for learning by doing.",
    tags: ["SOC Lab", "Detection", "Monitoring", "Investigation"],
    href: "https://github.com/GabrielReisSantos/MyhomeSOClab",
    linkLabel: "View repository →",
  },
];
---

<BaseLayout
  title="Projects | GabrielsMind"
  description="Projects focused on labs, architecture, security engineering, and technical documentation."
>
  <Hero
    eyebrow="Projects · Labs · Architecture · Security Engineering"
    title="My public projects"
    text="This section focuses on practical security projects: labs, workflows, architectures, and systems that show how I design, test, and think through technical problems."
    primaryHref="/reports/"
    primaryLabel="Read Research"
    secondaryHref="/contact/"
    secondaryLabel="Contact Me"
    imageSrc="/images/extra-dark.jpg"
    imageAlt="Gabriel working on a laptop in an urban environment"
  />

  <section class="intro-strip">
    <div class="container intro-strip-inner">
      <div class="intro-strip-card">
        <span class="intro-label">What belongs here</span>
        <p>Projects with clear objectives, design choices, and useful technical outcomes.</p>
      </div>

      <div class="intro-strip-card">
        <span class="intro-label">What does not</span>
        <p>Tool-driven write-ups with no real engineering logic.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <SectionIntro
      eyebrow="My work"
      title="Projects that show engineering judgment"
      text="These are the public projects that best reflect how I think through systems, trust boundaries, infrastructure decisions, and technical documentation."
    />

    <div class="grid grid-3">
      {flagshipProjects.map((project) => (
        <ProjectCard {...project} />
      ))}
    </div>
  </section>

  <section class="section research-section">
    <div class="research-panel">
      <div class="research-copy">
        <p class="eyebrow">Documents</p>
        <h2 class="section-title">Research & reports</h2>
        <p class="lead">
          This section brings together reports, write-ups, and presentation material that are meant to be read as structured deliverables.
        </p>

        <div class="button-row">
          <a class="button primary" href="/reports/">Open Reports Library</a>
          <a class="button secondary" href="https://medium.com/@gabrielreissantos" target="_blank" rel="noopener noreferrer">Visit Blog</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .intro-strip {
    position: relative;
    margin-top: -2rem;
    z-index: 3;
  }

  .intro-strip-inner {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
    padding: 0;
    border-radius: 22px;
    overflow: hidden;
    background: rgba(8, 14, 28, 0.62);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(14px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.24);
  }

  .intro-strip-card {
    padding: 1.25rem 1.5rem;
  }

  .intro-strip-card + .intro-strip-card {
    border-left: 1px solid rgba(255, 255, 255, 0.08);
  }

  .intro-label {
    display: inline-block;
    margin-bottom: 0.5rem;
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .intro-strip-card p {
    margin: 0;
    color: var(--text);
    line-height: 1.6;
  }

  .research-panel {
    border-radius: 24px;
    padding: 2rem;
    background: rgba(8, 14, 28, 0.62);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(14px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.24);
  }

  .research-copy {
    max-width: 760px;
  }

  .button-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  .live-map-frame {
    margin-top: 1.5rem;
    border-radius: 24px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(8, 14, 28, 0.72);
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.24);
  }

  .live-map-frame iframe {
    display: block;
    width: 100%;
    min-height: 344px;
  }

  @media (max-width: 900px) {
    .intro-strip-inner {
      grid-template-columns: 1fr;
    }

    .intro-strip-card + .intro-strip-card {
      border-left: 0;
      border-top: 1px solid rgba(255, 255, 255, 0.08);
    }
  }
</style>