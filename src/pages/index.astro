---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SectionIntro from "../components/SectionIntro.astro";
import FeatureCard from "../components/FeatureCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
---

<BaseLayout
  title="GabrielsMind | Cybersecurity Portfolio"
  description="Cybersecurity portfolio, labs, writeups, and projects by Gabriel."
>
  <Hero
    eyebrow="Cybersecurity · Labs · Detection · Automation"
    title="Who am I?"
    text="I am a junior cybersecurity analyst, focused on security operations, detection, and incident investigation. 
    This portfolio documents how I think, how I investigate, and how I translate security events into operational decisions. 
    Stay curious. Stay secure."
    primaryHref="https://github.com/GabrielReisSantos"
    primaryLabel="See Projects"
    secondaryHref="https://medium.com/@gabrielreissantos"
    secondaryLabel="Read the Blog"
    imageSrc="/images/hero-escalator.jpg"
    imageAlt="Gabriel in a cinematic urban environment"
  />

  <section class="intro-strip">
    <div class="container intro-strip-inner">
      <div>
        <span class="intro-label">Current direction</span>
        <p>
          Practical labs. Detection workflows. Security automation. Clear writeups.
        </p>
      </div>
      <div>
        <span class="intro-label">Built for</span>
        <p>
          Recruiters, engineers, SOC teams, and anyone who wants proof over buzzwords.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <SectionIntro
      eyebrow="Focus"
      title="What I focus on"
      text="Not vague cybersecurity branding. Actual practical work, documented clearly."
    />

    <div class="grid grid-3">
      <FeatureCard
        title="SOC & Detection Engineering"
        text="Alert triage, log pipelines, detection logic, and workflows that help analysts work faster and better."
      />
      <FeatureCard
        title="Security Labs & Automation"
        text="Hands-on lab environments with Wazuh, TheHive, Shuffle, Proxmox, and realistic adversary simulation."
      />
      <FeatureCard
        title="Research & Communication"
        text="Writeups that explain technical work clearly enough for engineers, managers, and security stakeholders."
      />
    </div>
  </section>

  <section class="section featured-projects">
    <SectionIntro
      eyebrow="Featured Work"
      title="Projects with real technical weight"
      text="A few examples of the work I’m building and documenting publicly."
    />

    <div class="grid grid-3">
      <ProjectCard
        title="SOC Lab Automation"
        text="Detection, enrichment, case handling, and response workflows built around Wazuh, TheHive, and Shuffle."
        tags={["Wazuh", "TheHive", "Shuffle", "SOC"]}
        href="/projects/"
      />
      <ProjectCard
        title="Phishing Triage Platform"
        text="A system to analyze suspicious emails, domains, and IPs with scoring, automation, and enrichment."
        tags={["Phishing", "Threat Intel", "Automation"]}
        href="/projects/"
      />
      <ProjectCard
        title="GabrielsMind Study Tools"
        text="AI-powered learning tools for document Q&A, flashcards, quizzes, and multilingual cybersecurity study."
        tags={["AI", "Study Tools", "Python"]}
        href="/projects/"
      />
    </div>
  </section>

  <section class="section closing-section">
    <div class="closing-grid">
      <div>
        <p class="eyebrow">Why this site exists</p>
        <h2 class="section-title">A cleaner public face for serious work</h2>
        <p class="lead">
          Most personal security sites are bloated or generic. This one is meant to be fast,
          focused, and built around real projects.
        </p>
      </div>

      <div class="closing-card">
        <p>
          The goal is simple: show how I think, what I build, and why the work matters.
        </p>

        <div class="button-row">
          <a class="button primary" href="/contact/">Contact Me</a>
          <a class="button secondary" href="/about/">More About Me</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .intro-strip {
      position: relative;
      margin-top: -2rem;
      z-index: 3;
    }

    .intro-strip-inner {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      padding: 1rem;
      border-radius: 22px;
      background: rgba(8, 14, 28, 0.62);
      border: 1px solid rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(14px);
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.24);
    }

    .intro-label {
      display: inline-block;
      margin-bottom: 0.45rem;
      color: var(--accent);
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .intro-strip p {
      margin: 0;
      color: var(--muted);
    }

    .featured-projects {
      position: relative;
    }

    .closing-grid {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 1.5rem;
      align-items: start;
    }

    .closing-card {
      padding: 1.5rem;
      border-radius: 24px;
      background: linear-gradient(180deg, rgba(20, 28, 52, 0.82), rgba(11, 18, 36, 0.95));
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 18px 48px rgba(0, 0, 0, 0.24);
    }

    .closing-card p {
      margin-top: 0;
      color: var(--muted);
    }

    @media (max-width: 900px) {
      .intro-strip-inner,
      .closing-grid {
        grid-template-columns: 1fr;
      }

      .intro-strip {
        margin-top: -1rem;
      }
    }
  </style>
</BaseLayout>
