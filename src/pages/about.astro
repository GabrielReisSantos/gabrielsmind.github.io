---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About | GabrielsMind" description="About Gabriel and the GabrielsMind project.">
  <section class="about-hero section">
    <div class="about-grid">
      <div>
        <p class="eyebrow">About</p>
        <h1 class="section-title">Practical security work, built and explained clearly.</h1>
        <p class="lead">
          GabrielsMind is my public portfolio for hands-on labs, detection workflows,
          incident response thinking, and technical projects that demonstrate real capability.
        </p>

        <div class="card">
          <p>
            My background combines leadership, operations, and technical cybersecurity work.
            I care about systems that do more than look impressive — they need to be useful,
            understandable, and deployable.
          </p>
          <p>
            This site is where I document that journey properly, without bloated branding
            or fake expertise.
          </p>
        </div>
      </div>

      <div class="about-image card image-shell">
        <img src="/images/about-reflection.jpg" alt="Gabriel working with a laptop in an urban setting" />
      </div>
    </div>
  </section>

  <style>
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 0.95fr;
      gap: 2rem;
      align-items: center;
    }

    .image-shell {
      padding: 0;
      overflow: hidden;
    }

    .image-shell img {
      width: 100%;
      height: 100%;
      min-height: 620px;
      object-fit: cover;
      display: block;
    }

    @media (max-width: 980px) {
      .about-grid {
        grid-template-columns: 1fr;
      }

      .image-shell img {
        min-height: 420px;
      }
    }
  </style>
</BaseLayout>
