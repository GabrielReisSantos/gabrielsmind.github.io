---
const platforms = [
  {
    name: "GitHub",
    href: "https://github.com/",
    icon: "◎",
  },
  {
    name: "LinkedIn",
    href: "https://www.linkedin.com/in/gabrielreis1712",
    icon: "in",
  },
  {
    name: "Substack",
    href: "#",
    icon: "☰",
  },
  {
    name: "Medium",
    href: "https://medium.com/",
    icon: "M",
  },
];
---

<section class="platform-strip-section">
  <div class="platform-strip">
    {platforms.map((platform) => (
      <a
        class="platform-card"
        href={platform.href}
        target="_blank"
        rel="noopener noreferrer"
      >
        <div class="platform-icon">{platform.icon}</div>
        <div class="platform-name">{platform.name}</div>
      </a>
    ))}
  </div>
</section>

<style>
  .platform-strip-section {
    padding: 0 0 3rem;
  }

  .platform-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-radius: 26px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(180deg, rgba(20, 28, 52, 0.82), rgba(11, 18, 36, 0.95));
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.24);
    backdrop-filter: blur(12px);
  }

  .platform-card {
    min-height: 180px;
    color: var(--text);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 1.5rem;
    text-align: center;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
    transition: transform 0.18s ease, background 0.18s ease, border-color 0.18s ease;
    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));
  }

  .platform-card:last-child {
    border-right: 0;
  }

  .platform-card:hover {
    transform: translateY(-2px);
    background: linear-gradient(180deg, rgba(94, 234, 212, 0.05), rgba(255,255,255,0.02));
  }

  .platform-icon {
    width: 72px;
    height: 72px;
    border-radius: 999px;
    display: grid;
    place-items: center;
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--text);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .platform-name {
    font-size: 1.15rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--text);
  }

  @media (max-width: 900px) {
    .platform-strip {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .platform-card:nth-child(2) {
      border-right: 0;
    }

    .platform-card:nth-child(1),
    .platform-card:nth-child(2) {
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }
  }

  @media (max-width: 560px) {
    .platform-strip {
      grid-template-columns: 1fr;
    }

    .platform-card {
      border-right: 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .platform-card:last-child {
      border-bottom: 0;
    }
  }
</style>