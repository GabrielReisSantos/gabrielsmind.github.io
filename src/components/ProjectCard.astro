---
interface Props {
  title: string;
  text: string;
  tags?: string[];
  href?: string;
  linkLabel?: string;
  label?: string;
}

const {
  title,
  text,
  tags = [],
  href,
  linkLabel = "Explore project →",
  label = "Project",
} = Astro.props;
---

<article class="project-card">
  <p class="project-label">{label}</p>
  <h3>{title}</h3>
  <p class="project-text">{text}</p>

  {tags.length > 0 && (
    <div class="project-tags">
      {tags.map((tag) => (
        <span>{tag}</span>
      ))}
    </div>
  )}

  {href && (
    <a
      class="project-link"
      href={href}
      target={href.startsWith("http") ? "_blank" : undefined}
      rel={href.startsWith("http") ? "noopener noreferrer" : undefined}
    >
      {linkLabel}
    </a>
  )}
</article>

<style>
  .project-card {
    border-radius: 26px;
    padding: 1.65rem;
    background: linear-gradient(180deg, rgba(13, 20, 40, 0.76), rgba(9, 16, 32, 0.9));
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.22);
    min-height: 100%;
    display: flex;
    flex-direction: column;
  }

  .project-label {
    margin: 0 0 0.8rem;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .project-card h3 {
    margin: 0 0 0.95rem;
    font-size: 1.95rem;
    line-height: 1.05;
  }

  .project-text {
    margin: 0 0 1.3rem;
    color: var(--muted);
    line-height: 1.7;
    flex-grow: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-bottom: 1.4rem;
  }

  .project-tags span {
    display: inline-flex;
    align-items: center;
    padding: 0.52rem 0.88rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--muted);
    font-size: 0.9rem;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    color: var(--text);
    text-decoration: none;
    font-weight: 700;
  }

  .project-link:hover {
    color: var(--accent);
  }
</style>